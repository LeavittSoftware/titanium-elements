{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "spec/tmp",
    "rootDir": ".",
    "types": ["jasmine", "node"],
    "sourceMap": true,
    "esModuleInterop": true
  },
  "include": ["packages/**/*.spec.ts", "packages/**/*.test.ts"],
  "exclude": ["**/*.d.ts", "**/*.css.ts", "node_modules"]
}
