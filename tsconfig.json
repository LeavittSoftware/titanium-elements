{
  "compilerOptions": {
    "target": "es2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declarationMap": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "experimentalDecorators": true,
    "noImplicitAny": false,
    "useDefineForClassFields": false,
    "declaration": true,
    "sourceMap": true,
    "noImplicitReturns": true,
    "alwaysStrict": true,
    "allowJs": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictNullChecks": true,
    "noEmitHelpers": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@leavittsoftware/web/*": ["./packages/web/*"]
    }
  },
  "include": ["packages/**/*.ts"],
  "exclude": ["**/*.d.ts", "**/*.css.ts", "**/*.test.ts", "**/*.spec.ts", "node_modules"]
}
